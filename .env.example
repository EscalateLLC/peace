# =============================================================================
# AI — Anthropic (artifact generation / structured extraction)
# =============================================================================

# Get your API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default model used by the pipeline
# PEACE_MODEL=claude-sonnet-4-6

# =============================================================================
# Speech-to-text — Deepgram (required for voice transcription)
# =============================================================================

# Get your API key: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# =============================================================================
# Text-to-speech — voice output
# =============================================================================
# Provider is chosen automatically: if ELEVENLABS_API_KEY is set it's used
# (most natural), otherwise Deepgram Aura, otherwise voice replies are disabled.

# ElevenLabs (recommended). Key: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice id — browse + copy from https://elevenlabs.io/app/voices (default: "Rachel").
# NOTE: free ElevenLabs plans CANNOT use library voices via the API (HTTP 402) —
# use a voice from your own VoiceLab, or upgrade. On failure peace falls back to Aura.
# PEACE_ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM
# Model (default eleven_turbo_v2_5; eleven_flash_v2_5 is fastest, eleven_multilingual_v2 highest quality)
# PEACE_ELEVENLABS_MODEL=eleven_turbo_v2_5

# Deepgram Aura voice (used as the runtime fallback, or when ELEVENLABS_API_KEY is unset)
# PEACE_TTS_MODEL=aura-2-thalia-en

# Playback volume, 0..2 (default 0.5 — raise/lower to taste)
# PEACE_TTS_VOLUME=0.5

# Pronunciation fixes: JSON map of name/word -> phonetic respelling, applied before
# synthesis (the reliable, provider-agnostic way to fix a garbled name).
# PEACE_TTS_LEXICON={"Xsno":"Ex-no","Sachit":"Suh-cheet"}

# =============================================================================
# Discord bot
# =============================================================================

# Create an application + bot: https://discord.com/developers/applications
# Required gateway intents: Guilds, Guild Messages, Message Content, Guild Voice States
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APP_ID=your_discord_application_id_here

# =============================================================================
# Local data
# =============================================================================

# SQLite database path, shared by bot-discord (writer), web, and cli.
# Relative paths resolve from the repo root.
PEACE_DB_PATH=./peace.db
