# Supply-chain hardening.
# Note: dependency lifecycle scripts are already blocked by pnpm 10+ by default;
# the explicit allowlist lives in pnpm-workspace.yaml (onlyBuiltDependencies).
# We deliberately do NOT set ignore-scripts=true globally — it would also block
# this project's own `prepare` (husky) hook.
save-exact=true
engine-strict=true
verify-deps-before-run=true
